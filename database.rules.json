{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "games": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "partyCodeIndex": {
      ".read": true,
      ".write": "auth != null"
    },
    "venues": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "cancelledGames": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "adminInvites": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$code": {
        ".read": true
      }
    },
    "photos": {
      ".read": "auth != null",
      ".write": false
    },
    "scans": {
      ".read": "auth != null",
      ".write": false
    },
    "scanLog": {
      ".read": "auth != null",
      ".write": false
    },
    "survey": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": false
    },
    "activeItems": {
      ".read": "auth != null",
      ".write": false
    },
    "bathroomScans": {
      ".read": "auth != null",
      ".write": false
    },
    "memoryReset": {
      ".read": "auth != null",
      ".write": false
    },
    "appVersion": {
      ".read": "auth != null",
      ".write": false
    },
    "testMode": {
      ".read": "auth != null",
      ".write": false
    },
    "$other": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": false
    }
  }
}
